# ---- Python (standard GitHub template, condensed) ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg
.venv/
venv/
env/
.python-version
