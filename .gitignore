# ---- Large or regenerable study artifacts (do NOT push) ----
# Root-anchored (leading /) so they do NOT also match src/data, tests/data, etc.
# CodeContests-derived benchmark: filtered problems + per-problem tests/solutions (large)
/benchmark/
# submissions, executions, labels, gold (large, regenerable)
/artifacts/
# regenerated by run.py build-figures / analysis steps
/results/figures/
/results/tables/
/results/stats/
# LLM call logs (may contain prompts; large)
/logs/

# ---- Manuscript: excluded from the public artifact repo ----
/paper/

# ---- Gold annotation: per-item detail files are regenerable from final.jsonl + seed ----
# (README, CODEBOOK, manifest, and the filled annotator CSVs ARE tracked)
/human/items/

# ---- LaTeX build by-products (in case paper/ is ever tracked elsewhere) ----
*.aux
*.bbl
*.blg
*.log
*.out
*.synctex.gz
*.fls
*.fdb_latexmk
main.pdf

# ---- Secrets ----
.env
*.key

# ---- macOS ----
.DS_Store
/scratch/

# ---- local state backups (large tarballs) ----
/backups/
